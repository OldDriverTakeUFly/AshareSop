# Davis WebUI Docker Environment

# Tushare API token (required for stock data)
TUSHARE_TOKEN=your_tushare_token_here

# Comma-separated list of allowed CORS origins
# Include your Cloudflare tunnel domain when configured
CORS_ORIGINS=https://davis.yourdomain.com

# Backend URL for Next.js server-side proxy (internal, same host)
FASTAPI_URL=http://localhost:8322

# Cloudflare Tunnel token (from Zero Trust dashboard)
# Get this from: Cloudflare Zero Trust → Networks → Tunnels → Create tunnel
TUNNEL_TOKEN=your_tunnel_token_here
