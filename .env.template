# ============================================================
# StockHot Dashboard Configuration
# Copy to .env and fill in your values: cp .env.template .env
# ============================================================

# --- FastAPI Backend ---
# Root directory of the project (used by config.py to resolve DB_PATH)
PROJECT_ROOT=/app

# API authentication password (default: stockhot)
# Override this for production!
STOCKHOT_API_PASSWORD=stockhot

# CORS allowed origins (comma-separated)
# For Cloudflare Tunnel: add your https://dashboard.yourdomain.com
CORS_ORIGINS=http://localhost:3000

# OpenAI API key (optional, for AI analysis features)
# OPENAI_API_KEY=sk-xxx

# --- Next.js Frontend ---
# FastAPI backend URL (used by Next.js rewrite proxy)
# In Docker with network_mode: host, use localhost
# In bridge network, use service name: http://backend:8321
FASTAPI_URL=http://localhost:8321

# --- LLM Provider Configuration (stockhot/advisor) ---
# Supported providers: glm, openai, deepseek (default: glm)
# LLM_PROVIDER=glm
# LLM_API_KEY=your-api-key-here
# Optional overrides (provider defaults are used if unset):
# LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
# LLM_MODEL=glm-5.2

# --- Cloudflare Tunnel ---
# Get your token from: https://one.dash.cloudflare.com → Networks → Tunnels
# Leave empty to skip tunnel (local access only)
# TUNNEL_TOKEN=eyJhIjoi...

# --- Telegram Bot Configuration (stockhot/notification) ---
# Get token from @BotFather
# TELEGRAM_BOT_TOKEN=your-bot-token
# Default chat/channel ID to send messages to
# TELEGRAM_CHAT_ID=-1001234567890
# Comma-separated list of allowed Telegram user IDs
# TELEGRAM_ALLOWED_USER_IDS=123456789,987654321
